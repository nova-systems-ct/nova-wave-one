# Supabase — from supabase.com project settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI — from console.anthropic.com API keys
ANTHROPIC_API_KEY=

# Google — from console.cloud.google.com credentials (enable Places API and PageSpeed API).
# Also used directly by Nova Reviews for Google Business review monitoring — no separate
# GOOGLE_PLACES_API_KEY needed, one key covers both.
GOOGLE_API_KEY=

# Phone and SMS (Twilio) — from twilio.com console dashboard
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Voice
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
RENDER_STREAM_URL=

# Email — from resend.com API keys
RESEND_API_KEY=

# Payments — from dashboard.stripe.com developers → API keys (Nova Finances invoicing)
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Social — from developers.facebook.com (your app's access token), used by Nova Social for
# Instagram/Facebook DMs, comments, and scheduled post publishing
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=nova-systems-2026
# From linkedin.com developer portal — not yet wired into Nova Social's publisher (Instagram
# and Facebook are live via META_ACCESS_TOKEN; LinkedIn needs its own OAuth app review first)
LINKEDIN_ACCESS_TOKEN=

# Content creation — from platform.stability.ai API keys (Nova Media AI image generation)
STABILITY_API_KEY=

# Where Isaac receives operational alerts (missed calls, low-confidence drafts, errors, hot-lead
# replies, daily briefings). Falls back to TWILIO_PHONE_NUMBER if unset — set this to Isaac's
# personal cell.
ISAAC_ALERT_PHONE=

# App config
VITE_APP_NAME=Nova Wave One
VITE_MAIN_SITE_URL=https://nova-systems.app
